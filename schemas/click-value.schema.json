{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Click",
  "type": "object",
  "additionalProperties": false,
  "required": ["click_id", "user", "page", "event_type"],
  "properties": {
    "click_id": {
      "type": "string"
    },
    "user": {
      "type": "string",
      "minLength": 1
    },
    "page": {
      "type": "string",
      "minLength": 1
    },
    "event_type": {
      "type": "string",
      "enum": ["view", "add_to_cart", "checkout"]
    }
  }
}
